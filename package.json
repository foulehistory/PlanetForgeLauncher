{
  "name": "launcher",
  "version": "1.0.1",
  "description": "PlanetForge Game Launcher",
  "repository": "https://github.com/foulehistory/PlanetForgeLauncher",
  "author": "PlanetForge",
  "main": "dist-main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:electron": "tsc -p tsconfig.json && electronmon .",
    "dev:renderer": "npm --prefix renderer run dev",
    "build:electron": "tsc -p tsconfig.json",
    "build": "npm run build:electron && npm --prefix renderer run build",
    "package": "npm run build && electron-builder --publish never",
    "package:win": "npm run build && electron-builder --win --publish never",
    "package:mac": "npm run build && electron-builder --mac --publish never",
    "package:linux": "npm run build && electron-builder --linux --publish never",
    "package:win:release": "npm run build && electron-builder --win --publish always",
    "package:mac:release": "npm run build && electron-builder --mac --publish always",
    "package:linux:release": "npm run build && electron-builder --linux --publish always"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.0",
    "typescript": "^6.0.3"
  },
  "build": {
    "appId": "com.planetforge.launcher",
    "productName": "PlanetForge",
    "asar": false,
    "files": [
      "dist-main/**/*",
      "renderer/dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release",
      "buildResources": "renderer/public"
    },
    "publish": {
      "provider": "github",
      "owner": "foulehistory",
      "repo": "PlanetForgeLauncher"
    },
    "win": {
      "target": "nsis",
      "icon": "renderer/public/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "renderer/public/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "renderer/public/icon.png",
      "category": "Game"
    }
  }
}
